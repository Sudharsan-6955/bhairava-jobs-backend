# ====================
# Server Configuration
# ====================
NODE_ENV=development
PORT=5000

# ====================
# Database Configuration
# ====================
# MongoDB Connection String
# Example: mongodb://localhost:27017/job-platform
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=your_mongodb_connection_string_here

# ====================
# JWT Configuration
# ====================
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secure_jwt_access_secret_minimum_64_characters_long
JWT_REFRESH_SECRET=your_super_secure_refresh_token_secret_minimum_64_characters_long

# ====================
# Cloudinary Configuration
# ====================
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ====================
# Client Configuration
# ====================
# Frontend URL for CORS (single or comma-separated)
# Example: https://admin.example.com,https://www.example.com
CLIENT_URL=http://localhost:3000

# ====================
# Optional: Email Configuration (for future features)
# ====================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_FROM=noreply@jobplatform.com
