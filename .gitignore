# ====================
# Node / Backend .gitignore (secure defaults)
# Keep lockfiles committed (do NOT ignore package-lock.json / yarn.lock)
# ====================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables - ignore all local env/secret files
.env
.env.*.local
.env.local
.env.development
.env.production
.env.test
.env.*.secret

# Secrets & private keys
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.asc
*.gpg
*.secret
secrets.*
credentials.*

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Build / Distribution
dist/
build/
.next/
out/

# Temporary Files
tmp/
temp/
.cache/
.cache-loader/
*.tmp

# Coverage Reports
coverage/
.nyc_output/

# OS Files
Thumbs.db

# Databases / local data
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# Uploads / user-generated content (may be stored in cloud in prod)
uploads/
uploads/**

# Runtime / process files
pids/
*.pid
*.seed

# Certificates / CSR
certs/
*.csr

# Editor histories
.history/

# Node REPL history
.node_repl_history

# Misc
# Keep an example env file in repo (commit .env.example)
